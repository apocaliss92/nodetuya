{
  "name": "@apocaliss92/nodetuya",
  "version": "0.2.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Node.js/TypeScript client for Tuya smart devices over the local network (encrypted LAN protocol 3.1–3.5 + UDP discovery)",
  "license": "MIT",
  "author": "apocaliss92",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/apocaliss92/nodetuya.git"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:e2e:live": "npm run build && node --env-file=.env scripts/e2e-live.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "tuya",
    "smartlife",
    "smart-home",
    "home-automation",
    "local",
    "lan",
    "iot",
    "localtuya"
  ],
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.1.0"
  }
}
